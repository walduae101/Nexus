{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Nexus app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat thread between the user and the Nexus.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message within a chat session.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model", "system"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "attachmentUrl": { "type": "string" },
        "attachmentType": { "type": "string" }
      },
      "required": ["sessionId", "userId", "role", "content", "timestamp"]
    },
    "GeneratedAsset": {
      "title": "GeneratedAsset",
      "description": "An asset (image, audio, video) generated by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "audio", "video"] },
        "url": { "type": "string" },
        "prompt": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "url", "prompt", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/chatSessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "Chat sessions."
    },
    "/chatSessions/{sessionId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Messages within a chat session."
    },
    "/generatedAssets/{assetId}": {
      "schema": { "$ref": "#/entities/GeneratedAsset" },
      "description": "Generated assets."
    }
  }
}
